{
  "name": "inline-constants",
  "displayName": "Inline Constants",
  "description": "Inline C/C++ macros, const, and constexpr usages with their resolved values.",
  "version": "0.0.1",
  "publisher": "srejv",
  "license": "MIT",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:c",
    "onLanguage:cpp",
    "onLanguage:cuda-cpp",
    "onLanguage:objective-c",
    "onLanguage:objective-cpp"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "inlineConstants.inlineAtCursor",
        "title": "Inline Constant",
        "category": "Inline Constants"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "inlineConstants.inlineAtCursor",
          "when": "editorTextFocus && inlineConstants.canInlineAtCursor",
          "group": "1_modification"
        }
      ]
    },
    "configuration": {
      "title": "Inline Constants",
      "properties": {
        "inlineConstants.clickBehavior": {
          "type": "string",
          "enum": [
            "disabled",
            "editorLink",
            "hoverLink"
          ],
          "default": "hoverLink",
          "markdownDescription": "Choose the optional click workflow. `hoverLink` shows a clickable action in the hover tooltip and is the recommended mode. `editorLink` turns same-file usages into editor links, but VS Code's built-in Go to Definition gesture may still take precedence."
        },
        "inlineConstants.parenthesizeExpressions": {
          "type": "boolean",
          "default": true,
          "description": "Wrap inserted expressions in parentheses when they contain top-level operators."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "test": "npm run compile && npm run test:unit && npm run test:integration",
    "test:integration": "node ./out/test/runTest.js",
    "test:unit": "node --test out/test/core.test.js",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.17.30",
    "@types/vscode": "^1.96.0",
    "@vscode/test-electron": "^2.5.2",
    "mocha": "^11.1.0",
    "typescript": "^5.8.3"
  }
}
