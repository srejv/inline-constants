{
  "name": "constants-replacement",
  "displayName": "Constants Replacement",
  "description": "Inline C/C++ constant usages from defines, const, and constexpr declarations.",
  "version": "0.0.1",
  "publisher": "localdev",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:constantsReplacement.replaceAtCursor",
    "onLanguage:c",
    "onLanguage:cpp",
    "onLanguage:cuda-cpp",
    "onLanguage:objective-c",
    "onLanguage:objective-cpp"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "constantsReplacement.replaceAtCursor",
        "title": "Replace Constant With Value",
        "category": "Constants Replacement"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "constantsReplacement.replaceAtCursor",
          "when": "editorTextFocus && constantsReplacement.canReplaceAtCursor",
          "group": "1_modification"
        }
      ]
    },
    "configuration": {
      "title": "Constants Replacement",
      "properties": {
        "constantsReplacement.clickBehavior": {
          "type": "string",
          "enum": [
            "disabled",
            "editorLink",
            "hoverLink"
          ],
          "default": "hoverLink",
          "markdownDescription": "Choose the optional click workflow. `hoverLink` shows a clickable action in the hover tooltip and is the recommended mode. `editorLink` turns same-file usages into editor links, but VS Code's built-in Go to Definition gesture may still take precedence."
        },
        "constantsReplacement.parenthesizeExpressions": {
          "type": "boolean",
          "default": true,
          "description": "Wrap inserted expressions in parentheses when they contain top-level operators."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "test": "npm run compile && node --test out/test/core.test.js",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.17.30",
    "@types/vscode": "^1.96.0",
    "typescript": "^5.8.3"
  }
}
