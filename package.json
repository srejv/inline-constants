{
  "name": "inline-constants",
  "displayName": "Inline Constants",
  "description": "Inline C/C++ macros, const, and constexpr usages with their resolved values.",
  "version": "0.0.1",
  "publisher": "srejv",
  "author": "Oscar Dragén",
  "repository": {
    "type": "git",
    "url": "https://github.com/srejv/inline-constants.git"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:c",
    "onLanguage:cpp",
    "onLanguage:cuda-cpp",
    "onLanguage:objective-c",
    "onLanguage:objective-cpp"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "inlineConstants.inlineAtCursor",
        "title": "Inline Constant",
        "category": "Inline Constants"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "inlineConstants.inlineAtCursor",
          "when": "editorTextFocus && inlineConstants.canInlineAtCursor",
          "group": "1_modification"
        }
      ]
    },
    "configuration": {
      "title": "Inline Constants",
      "properties": {
        "inlineConstants.clickBehavior": {
          "type": "string",
          "enum": [
            "disabled",
            "hoverLink"
          ],
          "default": "hoverLink",
          "markdownDescription": "Choose the optional click workflow. `hoverLink` shows a clickable action in the hover tooltip and is the recommended mode. `disabled` turns off click-driven inlining."
        },
        "inlineConstants.parenthesizeExpressions": {
          "type": "boolean",
          "default": true,
          "description": "Wrap inserted expressions in parentheses when they contain top-level operators."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "test": "npm run compile && npm run test:unit && npm run test:integration",
    "test:integration": "node ./out/test/runTest.js",
    "test:unit": "node --test out/test/core.test.js",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.17.30",
    "@types/vscode": "^1.96.0",
    "@vscode/test-electron": "^2.5.2",
    "mocha": "^11.1.0",
    "typescript": "^5.8.3"
  },
  "icon": "images/icon.png",
  "homepage": "https://github.com/srejv/inline-constants#readme",
  "bugs": {
    "url": "https://github.com/srejv/inline-constants/issues"
  },
  "keywords": [
    "c",
    "cpp",
    "c++",
    "constexpr",
    "const",
    "macro",
    "refactoring",
    "inline",
    "objective-c",
    "cuda"
  ],
  "galleryBanner": {
    "color": "#1f2937",
    "theme": "dark"
  }
}
